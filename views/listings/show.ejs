<% layout("/layouts/boilerplate.ejs") %>
<script>
    const mapToken = "<%= process.env.  MAPTOKEN %>";
</script>
<body>
<div class="row mt-3">
    <div class="col-8 offset-3">
        <h2>  <b> <%= listing.title %></b></h2>
    </div>
    <div class="card col-6 offset-3  show-card listing-cards">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listingimg" style="height: 20rem;">
        <!-- <div class="card-img-overlay"></div> -->
        <div class="card-body">
            <p class="card-text"> <%=listing.owner.username %> </p>
            <p class="card-text"><%= listing.description %></p>
            <p class="card-text">&#8377;<%= listing.price.toLocaleString("en-IN") %></p> 
            <p class="card-text"> <%= listing.location %> <br></p> 
            <p class="card-text"> <%= listing.country %> <br></p>
        </div>

        <br>
    <% if(currUser && currUser._id.equals(listing.owner._id)){%>
        <div class="btns">
            <a href="/listings/<%=listing._id%>/edit" class="edit-btn btn btn-dark col-3 offset-1 ">Edit</a>
            <form action="/listings/<%=listing._id%>/delete" method="post">
                <button type="submit" class="btn btn-dark offset-5">delete</button>
            </form>
        </div>
     <% } %>

    </div>
    <div class="col-8 offset-3 mb-3">
        <% if(currUser ){ %>
            <h4>Leave a Review</h4>
            <hr>
            <form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <!-- <input type="range" min="1" max="5" name="" class="form-range" id="rating"> -->
                
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea required name="review[comment]" id="comment" cols="30" rows="5" class="form-control"></textarea>
                    <div class="invalid-feedback">please add comment</div>
                </div>
                <button type="submit" class="addbtn btn btn-light">Submit</button>
            </form>
        <% } %>
        <div class="row">
            <h4>All reviews</h4>
            <% for(let reviews of listing.reviews){%>
                <div class="card col-5 mb-3 ms-3 ">
                    <div class="card-body">
                        <h5 class="card-title"> <%=reviews.author.username%></h5>
                        <p class="starability-result card-text" data-rating="<%=reviews.rating%>">
                        </p>
                        <p class="card-text"><%=reviews.comment%></p>
                    </div>
                    <form class="mb-2" method="post" action="/listings/<%=listing._id%>/reviews/<%=reviews._id%>?_method=DELETE">
                        <button class="btn btn-sm btn-dark ">delete</button>
                    </form>
                </div>
            <%} %>
            <% if(!listing.reviews[0]) {%>
                <hr>
                <h5>No reviews yet</h5>
            <% } %>
        </div>
    </div>
    
</div>
<div class="col-6 offset-3 mb-3">
    <h3>
        Where you will be
    </h3>
    <div id="myMap" style="position:relative;width:300px;height:300px;">

    </div>

    <script type='text/javascript'
 src='http://www.bing.com/api/maps/mapcontrol?callback=GetMap'
async defer></script>
 
 <script src="/js/map.js" type='text/javascript'>
    
 </script>

</div>
</body>
</html>